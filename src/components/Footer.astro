---
import ProviderIcon from "./ProviderIcon.astro";
---

<footer class="site-footer">
  <div class="footer-shell">
    <div class="footer-brand">
      <a class="brand-link footer-logo" href="#home" aria-label="Lumen Tidy home">
        <img
          src="/images/lumen-tidy/brand/logo_white.png"
          alt="web | Lumen Tidy"
          width="925"
          height="160"
        />
      </a>
      <p>Thoughtful cleaning for homes and workplaces that need reliable care without the fuss.</p>
      <div class="socials" aria-label="Social links">
        <a href="https://www.facebook.com/" target="_blank" rel="noreferrer" aria-label="Facebook"><ProviderIcon name="facebook" /></a>
        <a href="https://www.instagram.com/" target="_blank" rel="noreferrer" aria-label="Instagram"><ProviderIcon name="instagram" /></a>
        <a href="https://x.com/" target="_blank" rel="noreferrer" aria-label="X"><ProviderIcon name="x" /></a>
        <a href="https://www.linkedin.com/" target="_blank" rel="noreferrer" aria-label="LinkedIn"><ProviderIcon name="linkedin" /></a>
      </div>
    </div>
    <div class="footer-links">
      <div><a href="#home">Home</a><a href="#about-us">About us</a><a href="#services">Services</a></div>
      <div><a href="#team">Our team</a><a href="#testimonials">Reviews</a><a href="#contact-us">Contact</a></div>
    </div>
  </div>
  <div class="footer-bottom">
    <span>© 2026 Lumen Tidy. All rights reserved.</span>
    <span>Powered by WebDevful</span>
  </div>
</footer>
